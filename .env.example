FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace-with-your-secret
FEISHU_SEND_TO=personal

FEISHU_PERSONAL_RECEIVE_ID_TYPE=open_id
FEISHU_PERSONAL_RECEIVE_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

FEISHU_GROUP_RECEIVE_ID_TYPE=chat_id
FEISHU_GROUP_RECEIVE_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

FEISHU_BOT_USE_SDK=true
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_MENTION_NAME=MT Agent
FEISHU_BOT_PORT=8787
FEISHU_BOT_VERIFICATION_TOKEN=replace-with-event-verification-token
# Phase 1 HTTP callback fallback expects plaintext Feishu events. Leave Encrypt Key empty unless event decryption is implemented later.
FEISHU_BOT_ENCRYPT_KEY=
MT_AGENT_OUTPUT_DIR=output

# Legacy fallback. If personal fields are omitted, these are used as the personal target.
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_RECEIVE_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. When set, public-traffic-report reads goods-manager /api/goods
# and writes recent 7-day submitted product IDs into the 新品池维护 sheet.
GOODS_MANAGER_BASE_URL=http://192.168.1.22:3010
