{
  "name": "mt-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "daily-report": "tsx src/cli/dailyReport.ts",
    "test-feishu": "tsx src/cli/testFeishu.ts",
    "probe-page-size": "tsx src/cli/probePageSize.ts",
    "probe-exposure-page": "tsx src/cli/probeExposurePage.ts",
    "sync-product-id-map": "tsx src/cli/syncProductIdMap.ts",
    "refresh-product-id-map": "tsx src/cli/refreshProductIdMap.ts",
    "rebuild-latest": "tsx src/cli/rebuildLatestReport.ts",
    "public-traffic-report": "tsx src/cli/publicTrafficReport.ts",
    "closed-order-feedback:sync": "tsx src/cli/closedOrderFeedbackSync.ts",
    "closed-order-feedback:preview": "tsx src/cli/closedOrderFeedbackPreview.ts",
    "closed-order-observation:report": "tsx src/cli/closedOrderObservationReport.ts",
    "link-registry:audit": "tsx src/cli/linkRegistryAudit.ts",
    "link-registry:apply-audit-review": "tsx src/cli/linkRegistryApplyAuditReview.ts",
    "link-registry:group-review": "tsx src/cli/linkRegistryGroupReview.ts",
    "link-registry:apply-group-review": "tsx src/cli/linkRegistryApplyGroupReview.ts",
    "link-registry:merge-review": "tsx src/cli/linkRegistryMergeReview.ts",
    "link-registry:apply-merge-review": "tsx src/cli/linkRegistryApplyMergeReview.ts",
    "operations-learning-loop:preview": "tsx src/cli/operationsLearningLoopPreview.ts",
    "activity-automation:scout": "tsx src/cli/activityAutomation.ts",
    "capture-dashboard": "tsx src/cli/captureDashboard.ts",
    "agent:dry-run": "tsx src/cli/agentDryRun.ts",
    "feishu-bot": "tsx src/cli/feishuBot.ts",
    "feishu-bot:sdk": "tsx src/cli/feishuBotSdk.ts",
    "rental-price-skill:install": "npm --prefix vendor/rental-price-agent install",
    "rental-price-skill:init": "node vendor/rental-price-agent/scripts/init.js",
    "rental-price-skill:daemon:start": "node vendor/rental-price-agent/scripts/playwright-runner.js daemon start",
    "rental-price-skill:daemon:stop": "node vendor/rental-price-agent/scripts/playwright-runner.js daemon stop",
    "rental-price-skill:read": "node vendor/rental-price-agent/scripts/playwright-runner.js read",
    "rental-price-skill:apply": "node vendor/rental-price-agent/scripts/playwright-runner.js apply",
    "rental-price-skill:verify": "node vendor/rental-price-agent/scripts/playwright-runner.js verify",
    "rental-price-skill:batch:preview": "node vendor/rental-price-agent/scripts/batch-runner.js preview",
    "rental-price-skill:batch:execute": "node vendor/rental-price-agent/scripts/batch-runner.js execute",
    "feishu-bot:pm2:start": "pm2 start ecosystem.config.cjs --only mt-feishu-bot",
    "feishu-bot:pm2:restart": "pm2 restart mt-feishu-bot --update-env",
    "feishu-bot:pm2:stop": "pm2 stop mt-feishu-bot",
    "feishu-bot:pm2:status": "pm2 status mt-feishu-bot",
    "feishu-bot:pm2:logs": "pm2 logs mt-feishu-bot --lines 80",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.66.1",
    "playwright": "^1.52.0",
    "xlsx-js-style": "^1.2.0"
  },
  "overrides": {
    "axios": "1.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
